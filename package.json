{
  "name": "ai_lessons",
  "version": "0.1.0",
  "description": "AgentSchool - mine coding-agent sessions for durable AGENTS.md guidance",
  "type": "module",
  "scripts": {
    "dev": "run-p dev:frontend dev:backend",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch server/index.ts",
    "build": "vite build",
    "build:backend": "tsc --outDir dist/server server/index.ts",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@langchain/anthropic": "^0.1.0",
    "@langchain/aws": "^0.1.15",
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.0.1",
    "@langchain/openai": "^0.1.0",
    "@monaco-editor/react": "^4.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsdom": "^29.1.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^8.56.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  }
}
